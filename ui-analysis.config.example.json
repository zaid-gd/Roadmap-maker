{
  "enabled": true,
  "mode": "development",
  "rules": {
    "layout": {
      "checkOverflow": true,
      "checkAlignment": true,
      "checkSpacing": true,
      "checkZIndex": true
    },
    "responsive": {
      "minTouchTargetSize": {
        "width": 44,
        "height": 44
      },
      "breakpoints": [640, 768, 1024, 1280],
      "allowHorizontalScroll": false
    },
    "accessibility": {
      "wcagLevel": "AA",
      "checkKeyboard": true,
      "checkFocus": true,
      "checkContrast": true,
      "checkReducedMotion": true
    },
    "designSystem": {
      "enforceTokens": true,
      "allowedArbitraryValues": [],
      "strictMode": false
    }
  },
  "breakpoints": [
    {
      "name": "mobile",
      "width": 375,
      "height": 667
    },
    {
      "name": "tablet",
      "width": 768,
      "height": 1024
    },
    {
      "name": "desktop",
      "width": 1280,
      "height": 800
    },
    {
      "name": "wide",
      "width": 1920,
      "height": 1080
    }
  ],
  "reporting": {
    "console": true,
    "overlay": true,
    "json": false,
    "outputPath": "./ui-analysis-report.json",
    "minSeverity": "minor"
  }
}
